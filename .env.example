# ─── AARKAAI Backend – Environment Variables ─────────────────────────────────
# Copy this file to .env and fill in values for your environment.
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your values
#   source .env  (or use python-dotenv)

# ─── Environment ─────────────────────────────────────────────────────────────
AARKAAI_ENV=production                    # "development" | "production"

# ─── Security ────────────────────────────────────────────────────────────────
AARKAAI_API_KEY=your-secret-api-key-here  # Required in production
AARKAAI_ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# ─── Rate Limiting ───────────────────────────────────────────────────────────
AARKAAI_RATE_LIMIT_RPM=30                 # Max requests per minute per IP
AARKAAI_RATE_LIMIT_ENABLED=true           # Explicit enable (auto-enabled in prod)

# ─── Input ───────────────────────────────────────────────────────────────────
AARKAAI_MAX_QUERY_LENGTH=2000             # Max characters per query

# ─── Server ──────────────────────────────────────────────────────────────────
AARKAAI_BASE_URL=https://api.yourdomain.com
AARKAAI_HOST=0.0.0.0
AARKAAI_PORT=5000
AARKAAI_WORKERS=1                          # Keep at 1 for llama.cpp (shared model)

# ─── Database ────────────────────────────────────────────────────────────────
# AARKAAI_DB_URL=sqlite:///aarkaai.db     # Default (SQLite)
# AARKAAI_DB_URL=postgresql://user:pass@localhost:5432/aarkaai  # PostgreSQL

# ─── Tool Sandboxing ────────────────────────────────────────────────────────
AARKAAI_SAFE_DIR=/home/azureuser/aarkaai3b/workspace
AARKAAI_BASH_TIMEOUT=30                   # Max seconds per shell command

# ─── Logging ─────────────────────────────────────────────────────────────────
AARKAAI_LOG_LEVEL=INFO                    # DEBUG | INFO | WARNING | ERROR
