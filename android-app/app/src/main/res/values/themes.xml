<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.AarkaaiApp" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@color/claude_bg_light</item>
        <item name="android:navigationBarColor">@color/claude_bg_light</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Theme.AarkaaiApp.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/splash_bg</item>
        <item name="postSplashScreenTheme">@style/Theme.AarkaaiApp</item>
    </style>
</resources>
